<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ZestyySports" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/red_accent</item>
        <item name="colorPrimaryVariant">@color/red_accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>
        <item name="chipStyle">@style/ZestyyChipStyle</item>
    </style>

    <style name="ZestyyChipStyle" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_selector_bg</item>
        <item name="android:textColor">@color/chip_selector_text</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipStrokeColor">#2A2A2A</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
    </style>
</resources>
